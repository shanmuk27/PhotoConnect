<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.chip.Chip
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/chip"
    android:layout_width="wrap_content" android:layout_height="44dp"
    android:layout_marginEnd="8dp"
    android:checkable="true"
    android:clickable="true"
    style="@style/Widget.Material3.Chip.Filter"
    app:chipCornerRadius="22dp"
    android:textSize="14sp"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    app:chipStrokeWidth="1dp"
    app:chipStrokeColor="@color/category_chip_stroke"
    app:chipBackgroundColor="@color/category_chip_bg"
    android:textColor="@color/category_chip_text"
    app:checkedIconVisible="false" />
