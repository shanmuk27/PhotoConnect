    <string name="tour_explore_services_title">सेवां चिनोतु (%1$d/%2$d)</string>
    <string name="tour_explore_services_body">निर्मातृसूचीं संक्षिप्तां कर्तुं विवाहं व्यक्तिचित्रं वा चलच्चित्रसेवां चिनोतु।</string>
    <string name="tour_explore_results_title">निर्मातृपत्राणि (%1$d/%2$d)</string>
    <string name="tour_explore_results_body">चित्रं मूल्याङ्कनं सेवां दूरीं विश्वासचिह्नानि च पश्यतु। विवरणाय पत्रं प्रियसञ्चयाय हृदयचिह्नं स्पृशतु।</string>
    <string name="tour_explore_filters_title">समीपपरिणामान् शोधयतु (%1$d/%2$d)</string>
    <string name="tour_explore_filters_body">परिधिं 100 km पर्यन्तं परिवर्त्य दिनाङ्कं उपलब्धतां विश्वासं शीघ्रप्रतिक्रियां च शोधकान् योजयतु।</string>
    <string name="tour_client_1_title">निर्मातारं अन्विष्यतु (%1$d/%2$d)</string>
    <string name="tour_client_1_body">समीपस्थान् छायाचित्रकारान् निर्मातॄंश्च अन्वेषणे पश्यतु।</string>
    <string name="tour_client_2_title">दिनाङ्केन शोधयतु (%1$d/%2$d)</string>
    <string name="tour_client_2_body">दिनाङ्कं चित्वा तस्मिन् दिने उपलब्धान् निर्मातॄन् पश्यतु।</string>
    <string name="tour_client_3_title">निर्मातॄन् तुलयतु (%1$d/%2$d)</string>
    <string name="tour_client_3_body">द्वयोः आरभ्य चतुर्णां मूल्याङ्कनं सेवा दूरी उपलब्धता च तुलयतु।</string>
    <string name="tour_client_4_title">भवतः आरक्षणानि (%1$d/%2$d)</string>
    <string name="tour_client_4_body">आरक्षणं भुगतानं कार्यक्रमस्थितिं च अत्र पश्यतु।</string>
    <string name="tour_client_5_title">नवीनसूचनां प्राप्नोतु (%1$d/%2$d)</string>
    <string name="tour_client_5_body">आरक्षणं अनुमोदनं महत्त्वपूर्णसन्देशांश्च सूचनासु पश्यतु।</string>
    <string name="tour_client_6_title">भवतः प्रोफाइल् (%1$d/%2$d)</string>
    <string name="tour_client_6_body">लेखां भाषां गोपनीयतां सहायतां च अत्र व्यवस्थापयतु।</string>
    <string name="tour_creator_1_title">भवतः नियन्त्रणपटलम् (%1$d/%2$d)</string>
    <string name="tour_creator_1_body">पञ्चाङ्गे उपलब्धान् व्यस्तान् च दिनाङ्कान् व्यवस्थापयतु।</string>
    <string name="tour_creator_2_title">उपलब्धतां स्थापयतु (%1$d/%2$d)</string>
    <string name="tour_creator_2_body">दिनाङ्कं चित्वा Available अथवा Busy इति चिह्नयतु।</string>
    <string name="tour_creator_3_title">आरक्षणानि व्यवस्थापयतु (%1$d/%2$d)</string>
    <string name="tour_creator_3_body">ग्राहकनिवेदनं भुगतानं कार्यक्रमस्थितिं च पश्यतु।</string>
    <string name="tour_creator_4_title">भवतः कार्यसञ्चयः (%1$d/%2$d)</string>
    <string name="tour_creator_4_body">सार्वजनिकप्रोफाइल् सेवाः चित्राणि लेखाविकल्पांश्च व्यवस्थापयतु।</string>
    <string name="tour_creator_5_title">चित्राणि आरोपयतु (%1$d/%2$d)</string>
    <string name="tour_creator_5_body">स्वशैलीं गुणवत्तां च दर्शयितुं श्रेष्ठं कार्यं प्रकाशयतु।</string>
    <string name="tour_creator_6_title">सत्यापनं सम्पूरयतु (%1$d/%2$d)</string>
    <string name="tour_creator_6_body">परिचयं कार्यसञ्चयं सामाजिकप्रमाणं च सम्पूर्य विश्वासं वर्धयतु।</string>
    <string name="tour_guest_1_title">स्वागतम् (%1$d/%2$d)</string>
    <string name="tour_guest_1_body">प्रवेशात् पूर्वमपि समीपस्थान् निर्मातॄन् द्रष्टुं शक्नोति।</string>
    <string name="tour_guest_2_title">शीघ्रम् अन्विष्यतु (%1$d/%2$d)</string>
    <string name="tour_guest_2_body">नगरं सेवां निर्मातुः नाम वा लिखित्वा अन्विष्यतु।</string>
    <string name="tour_guest_3_title">प्रविशतु (%1$d/%2$d)</string>
    <string name="tour_guest_3_body">प्रियसञ्चयाय आरक्षणाय सूचनाभ्यश्च प्रविशतु।</string>
