<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="10dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <View
        android:layout_width="44dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="18dp"
        android:background="@drawable/bg_profile_skeleton" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/account_menu"
        android:textColor="?attr/colorOnSurface"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/account_menu_subtitle"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/menuProfileSettings"
        style="@style/Widget.PhotoConnect.ProfileMenuRow"
        android:layout_marginTop="18dp">

        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuIcon" android:src="@android:drawable/ic_menu_manage" />
        <TextView
            android:id="@+id/menuProfileSettingsText"
            style="@style/Widget.PhotoConnect.ProfileMenuText"
            android:text="@string/profile_settings" />
        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuChevron" />
    </LinearLayout>



    <LinearLayout
        android:id="@+id/menuSaved"
        style="@style/Widget.PhotoConnect.ProfileMenuRow">

        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuIcon" android:src="@drawable/ic_bookmark_outline" />
        <TextView style="@style/Widget.PhotoConnect.ProfileMenuText" android:text="@string/account_saved" />
        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuChevron" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menuLiked"
        style="@style/Widget.PhotoConnect.ProfileMenuRow">

        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuIcon" android:src="@drawable/ic_favorite_outline" />
        <TextView style="@style/Widget.PhotoConnect.ProfileMenuText" android:text="@string/account_liked" />
        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuChevron" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menuLanguage"
        style="@style/Widget.PhotoConnect.ProfileMenuRow">

        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuIcon" android:src="@drawable/ic_language" />
        <TextView style="@style/Widget.PhotoConnect.ProfileMenuText" android:text="@string/settings_language" />
        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuChevron" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menuAppTour"
        style="@style/Widget.PhotoConnect.ProfileMenuRow">

        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuIcon" android:src="@android:drawable/ic_dialog_map" />
        <TextView style="@style/Widget.PhotoConnect.ProfileMenuText" android:text="@string/app_tour_replay" />
        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuChevron" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menuHelp"
        style="@style/Widget.PhotoConnect.ProfileMenuRow">

        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuIcon" android:src="@android:drawable/ic_menu_help" />
        <TextView style="@style/Widget.PhotoConnect.ProfileMenuText" android:text="@string/help_support" />
        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuChevron" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menuLogs"
        style="@style/Widget.PhotoConnect.ProfileMenuRow">

        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuIcon" android:src="@android:drawable/ic_menu_info_details" />
        <TextView style="@style/Widget.PhotoConnect.ProfileMenuText" android:text="@string/settings_sync_logs" />
        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuChevron" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menuPrivacy"
        style="@style/Widget.PhotoConnect.ProfileMenuRow">

        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuIcon" android:src="@drawable/ic_lock" />
        <TextView style="@style/Widget.PhotoConnect.ProfileMenuText" android:text="@string/privacy" />
        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuChevron" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/theme"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/theme_selector_hint"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/themeToggleGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_theme_toggle_container"
            android:padding="4dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnThemeSystem"
                style="@style/Widget.PhotoConnect.ToggleButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/theme_system" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnThemeLight"
                style="@style/Widget.PhotoConnect.ToggleButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/theme_light" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnThemeDark"
                style="@style/Widget.PhotoConnect.ToggleButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/theme_dark" />
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menuSignOut"
        style="@style/Widget.PhotoConnect.ProfileMenuRow">

        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuIcon" android:src="@drawable/ic_logout" app:tint="?attr/colorError" />
        <TextView style="@style/Widget.PhotoConnect.ProfileMenuText" android:text="@string/logout" android:textColor="?attr/colorError" />
        <ImageView style="@style/Widget.PhotoConnect.ProfileMenuChevron" app:tint="?attr/colorError" />
    </LinearLayout>
</LinearLayout>
