<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarAnalytics"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="@string/analytics_title"
        app:titleCentered="true"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="?attr/colorOnSurface" />
        
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:scrollbars="none">
        
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleTimeRange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">
            
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRange3Months"
                style="@style/Widget.PhotoConnect.ToggleButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="@string/analytics_range_3_months" />
                
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRange6Months"
                style="@style/Widget.PhotoConnect.ToggleButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="@string/analytics_range_6_months" />
                
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRangeYear"
                style="@style/Widget.PhotoConnect.ToggleButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="@string/analytics_range_this_year" />
                
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRangeAllTime"
                style="@style/Widget.PhotoConnect.ToggleButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="@string/events_all_time" />
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </HorizontalScrollView>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:clipToPadding="false"
            android:paddingBottom="100dp">

            <!-- KPIs row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_metric_card"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/analytics_total_revenue"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView
                        android:id="@+id/tvTotalRevenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_metric_card"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/analytics_total_events"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView
                        android:id="@+id/tvTotalEvents"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>
            </LinearLayout>

            <!-- KPIs row 2: Upcoming vs Realized -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:baselineAligned="false">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_metric_card"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/analytics_upcoming_income"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView
                        android:id="@+id/tvUpcomingRevenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_metric_card_primary"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/analytics_realized_income"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurface" />
                    <TextView
                        android:id="@+id/tvRealizedRevenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>
            </LinearLayout>

            <!-- Chart Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/analytics_monthly_revenue_trend"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp"
                android:textColor="?attr/colorOnSurface" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_event_scope_toggle"
                android:padding="16dp">
                
                <LinearLayout
                    android:id="@+id/layoutChartBars"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:baselineAligned="false">
                    <!-- Bars injected dynamically here -->
                </LinearLayout>
                
                <TextView
                    android:id="@+id/tvEmptyChart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/analytics_not_enough_data"
                    android:visibility="gone"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </FrameLayout>
            
            <LinearLayout
                android:id="@+id/layoutChartLabels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="16dp">
                <!-- Labels injected dynamically here -->
            </LinearLayout>

            <!-- Upcoming vs Passed Away Report -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/analytics_event_status_breakdown"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp"
                android:textColor="?attr/colorOnSurface" />
                
            <LinearLayout
                android:id="@+id/layoutStatusBreakdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp">
                <!-- Coming/Passed rows injected here -->
            </LinearLayout>

            <!-- Service Breakdown -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/analytics_revenue_by_service"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp"
                android:textColor="?attr/colorOnSurface" />
                
            <LinearLayout
                android:id="@+id/layoutServiceBreakdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp">
                <!-- Service rows injected here -->
            </LinearLayout>

            <!-- Outstanding Balances -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/analytics_outstanding_balances"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp"
                android:textColor="?attr/colorOnSurface" />
                
            <LinearLayout
                android:id="@+id/layoutOutstanding"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp">
                <!-- Outstanding rows injected here -->
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
