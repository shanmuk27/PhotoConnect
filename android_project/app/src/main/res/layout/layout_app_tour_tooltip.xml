<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_tour_trendy"
    android:padding="20dp"
    android:elevation="12dp">

    <TextView
        android:id="@+id/tvTourProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:textColor="#B3FFFFFF"
        android:textStyle="bold"
        android:letterSpacing="0"
        android:textAllCaps="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="STEP 1 OF 6" />

    <TextView
        android:id="@+id/tvTourTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textAppearance="?attr/textAppearanceHeadlineSmall"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toBottomOf="@id/tvTourProgress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Discover Creators" />

    <TextView
        android:id="@+id/tvTourBody"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="#E6FFFFFF"
        android:lineSpacingExtra="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvTourTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Tap here to find the best creators near you. Browse portfolios, compare styles, and read real reviews." />

    <LinearLayout
        android:id="@+id/llTourControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/tvTourBody"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/btnTourSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tour_skip"
            android:textColor="#B3FFFFFF"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:paddingVertical="8dp"
            android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvTourTapHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tour_tap_to_continue"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="#FFFFFF"
            android:visibility="gone"
            android:minHeight="48dp"
            android:gravity="center_vertical" />

        <TextView
            android:id="@+id/btnTourNext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tour_next"
            android:textColor="#FFFFFF"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:minHeight="48dp"
            android:gravity="center"
            android:background="@drawable/bg_notification_badge"
            android:backgroundTint="#4DFFFFFF"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
