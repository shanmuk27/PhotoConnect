    <string name="tour_explore_services_title">सेवाएं चुनें (%1$d/%2$d)</string>
    <string name="tour_explore_services_body">क्रिएटर सूची को तुरंत सीमित करने के लिए शादी, पोर्ट्रेट या वीडियो जैसी सेवा चुनें।</string>
    <string name="tour_explore_results_title">क्रिएटर कार्ड (%1$d/%2$d)</string>
    <string name="tour_explore_results_body">फोटो, रेटिंग, सेवाएं, दूरी और भरोसे के संकेत देखें। जानकारी के लिए कार्ड या पसंदीदा सेव करने के लिए दिल दबाएं।</string>
    <string name="tour_explore_filters_title">नजदीकी परिणाम सुधारें (%1$d/%2$d)</string>
    <string name="tour_explore_filters_body">रेडियस को 100 km तक बदलें और तारीख, उपलब्धता, भरोसा तथा तेज जवाब वाले फिल्टर लगाएं।</string>
    <string name="tour_client_1_title">क्रिएटर खोजें (%1$d/%2$d)</string>
    <string name="tour_client_1_body">Explore में शहर, सेवा, नाम या पास के क्षेत्र से क्रिएटर खोजें। खोज 100 km तक radius बढ़ा सकती है और हर परिणाम का कारण दिखाती है।</string>
    <string name="tour_client_2_title">तारीख से फ़िल्टर करें (%1$d/%2$d)</string>
    <string name="tour_client_2_body">अपनी तारीख चुनकर केवल उस दिन उपलब्ध क्रिएटर देखें।</string>
    <string name="tour_client_3_title">क्रिएटर की तुलना करें (%1$d/%2$d)</string>
    <string name="tour_client_3_body">दो से चार क्रिएटर चुनकर उनकी रेटिंग, सेवाएं, दूरी और उपलब्धता साथ में देखें।</string>
    <string name="tour_client_4_title">My Bookings (%1$d/%2$d)</string>
    <string name="tour_client_4_body">Events tab में bookings, payments, pending dues, calls, sharing और booking status एक जगह मिलते हैं।</string>
    <string name="tour_client_5_title">Notifications (%1$d/%2$d)</string>
    <string name="tour_client_5_body">Bell में booking updates, messages, approvals और reminders दिखते हैं। पढ़ने के बाद Mark all as read दबाएं।</string>
    <string name="tour_client_6_title">Account और help (%1$d/%2$d)</string>
    <string name="tour_client_6_body">Account में language बदलें, studio verify करें, profile update करें, support लें, privacy देखें और यह tour फिर खोलें।</string>
    <string name="tour_creator_1_title">Creator dashboard (%1$d/%2$d)</string>
    <string name="tour_creator_1_body">Dashboard availability से शुरू होता है। Available, busy या booked dates mark करें ताकि clients सही date request करें।</string>
    <string name="tour_creator_2_title">उपलब्धता तय करें (%1$d/%2$d)</string>
    <string name="tour_creator_2_body">तारीख चुनकर Available या Busy करें, ताकि क्लाइंट सही दिन बुक कर सकें।</string>
    <string name="tour_creator_3_title">Client bookings (%1$d/%2$d)</string>
    <string name="tour_creator_3_body">Events Notebook में client events, payments, pending dues, calls, sharing, cancellation status और analytics रहते हैं।</string>
    <string name="tour_creator_4_title">आपका पोर्टफोलियो (%1$d/%2$d)</string>
    <string name="tour_creator_4_body">अपनी सार्वजनिक प्रोफ़ाइल, सेवाएं, फोटो और अकाउंट विकल्प यहां संभालें।</string>
    <string name="tour_creator_5_title">फोटो अपलोड करें (%1$d/%2$d)</string>
    <string name="tour_creator_5_body">अपना बेहतरीन काम पोस्ट करें, ताकि क्लाइंट आपकी शैली और गुणवत्ता देख सकें।</string>
    <string name="tour_creator_6_title">सत्यापन पूरा करें (%1$d/%2$d)</string>
    <string name="tour_creator_6_body">पहचान, पोर्टफोलियो और सोशल प्रमाण पूरा करके क्लाइंट का भरोसा बढ़ाएं।</string>
    <string name="tour_guest_1_title">Welcome (%1$d/%2$d)</string>
    <string name="tour_guest_1_body">Sign in से पहले भी creators explore कर सकते हैं। Search, services और location hints से nearby options देखें।</string>
    <string name="tour_guest_2_title">काम करने के लिए sign in करें (%1$d/%2$d)</string>
    <string name="tour_guest_2_body">Favorites save, booking, review, notifications या अपना profile manage करने के लिए sign in करें।</string>
    <string name="tour_guest_3_title">Language और support (%1$d/%2$d)</string>
    <string name="tour_guest_3_body">Account से app language बदलें, support contact करें और जरूरत पड़ने पर यह tour फिर खोलें।</string>
