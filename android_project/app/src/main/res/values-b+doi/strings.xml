    <string name="tour_explore_services_title">सेवां चुनो (%1$d/%2$d)</string>
    <string name="tour_explore_services_body">क्रिएटर सूची घट्ट करने आस्तै ब्याह, पोर्ट्रेट जां वीडियो सेवा चुनो।</string>
    <string name="tour_explore_results_title">क्रिएटर कार्ड (%1$d/%2$d)</string>
    <string name="tour_explore_results_body">फोटो, रेटिंग, सेवा, दूरी ते भरोसे दे संकेत दिक्खो। जानकारी आस्तै कार्ड ते पसंद आस्तै दिल टैप करो।</string>
    <string name="tour_explore_filters_title">नेड़े दे नतीजे सुधारो (%1$d/%2$d)</string>
    <string name="tour_explore_filters_body">रेडियस 100 km तगर बदलो ते तरीक, उपलब्धता, भरोसा ते तेज जवाब फिल्टर लाओ।</string>
    <string name="tour_client_1_title">क्रिएटर तुप्पो (%1$d/%2$d)</string>
    <string name="tour_client_1_body">नेड़े दे फोटोग्राफर ते क्रिएटर एक्सप्लोर च दिक्खो।</string>
    <string name="tour_client_2_title">तरीक कन्नै फिल्टर करो (%1$d/%2$d)</string>
    <string name="tour_client_2_body">तरीक चुनियै उस दिन उपलब्ध क्रिएटर दिक्खो।</string>
    <string name="tour_client_3_title">क्रिएटर दा मुकाबला करो (%1$d/%2$d)</string>
    <string name="tour_client_3_body">दो थमां चार क्रिएटर दी रेटिंग, सेवा, दूरी ते उपलब्धता दिक्खो।</string>
    <string name="tour_client_4_title">तुंदियां बुकिंगां (%1$d/%2$d)</string>
    <string name="tour_client_4_body">बुकिंग, पेमेंट ते इवेंट दी स्थिति इत्थें दिक्खो।</string>
    <string name="tour_client_5_title">अपडेट पाओ (%1$d/%2$d)</string>
    <string name="tour_client_5_body">बुकिंग, मंजूरी ते जरूरी संदेश सूचनाएं च दिक्खो।</string>
    <string name="tour_client_6_title">तुंदी प्रोफाइल (%1$d/%2$d)</string>
    <string name="tour_client_6_body">खाता, भाशा, प्राइवेसी ते मदद इत्थें संभालो।</string>
    <string name="tour_creator_1_title">तुंदा डैशबोर्ड (%1$d/%2$d)</string>
    <string name="tour_creator_1_body">कैलेंडर च उपलब्ध ते व्यस्त तरीकां संभालो।</string>
    <string name="tour_creator_2_title">उपलब्धता सेट करो (%1$d/%2$d)</string>
    <string name="tour_creator_2_body">तरीक चुनियै Available जां Busy निशान लाओ।</string>
    <string name="tour_creator_3_title">बुकिंगां संभालो (%1$d/%2$d)</string>
    <string name="tour_creator_3_body">क्लाइंट दी दरखास्त, पेमेंट ते इवेंट स्थिति दिक्खो।</string>
    <string name="tour_creator_4_title">तुंदा पोर्टफोलियो (%1$d/%2$d)</string>
    <string name="tour_creator_4_body">पब्लिक प्रोफाइल, सेवां, फोटो ते खाते दे विकल्प संभालो।</string>
    <string name="tour_creator_5_title">फोटो अपलोड करो (%1$d/%2$d)</string>
    <string name="tour_creator_5_body">अपना अंदाज ते गुणवत्ता दस्सने आस्तै बेहतरीन कम्म पोस्ट करो।</string>
    <string name="tour_creator_6_title">तस्दीक पूरी करो (%1$d/%2$d)</string>
    <string name="tour_creator_6_body">पहचान, पोर्टफोलियो ते सोशल सबूत पूरे करियै भरोसा बधाओ।</string>
    <string name="tour_guest_1_title">सुआगत ऐ (%1$d/%2$d)</string>
    <string name="tour_guest_1_body">साइन इन शा पैह्लें बी नेड़े दे क्रिएटर दिक्खी सकदे ओ।</string>
    <string name="tour_guest_2_title">छेती तुप्पो (%1$d/%2$d)</string>
    <string name="tour_guest_2_body">शहर, सेवा जां क्रिएटर दा नां लिखियै तुप्पो।</string>
    <string name="tour_guest_3_title">साइन इन करो (%1$d/%2$d)</string>
    <string name="tour_guest_3_body">फेवरेट सेव, बुकिंग ते सूचनाएं आस्तै साइन इन करो।</string>
