    <string name="tour_explore_services_body">ಪಟ್ಟಿಯನ್ನು ತಕ್ಷಣ ಕಡಿಮೆ ಮಾಡಲು ಮದುವೆ, ಪೋರ್ಟ್ರೇಟ್ ಅಥವಾ ವೀಡಿಯೊ ಸೇವೆಯನ್ನು ಆಯ್ಕೆಮಾಡಿ.</string>
    <string name="tour_explore_results_title">ಕ್ರಿಯೇಟರ್ ಕಾರ್ಡ್‌ಗಳು (%1$d/%2$d)</string>
    <string name="tour_explore_results_body">ಚಿತ್ರ, ರೇಟಿಂಗ್, ಸೇವೆ, ದೂರ ಮತ್ತು ವಿಶ್ವಾಸದ ಸೂಚನೆ ನೋಡಿ. ವಿವರಕ್ಕೆ ಕಾರ್ಡ್ ಮತ್ತು ಫೇವರಿಟ್‌ಗೆ ಹೃದಯ ಟ್ಯಾಪ್ ಮಾಡಿ.</string>
    <string name="tour_explore_filters_title">ಹತ್ತಿರದ ಫಲಿತಾಂಶ ಸುಧಾರಿಸಿ (%1$d/%2$d)</string>
    <string name="tour_explore_filters_body">ರೇಡಿಯಸ್ ಅನ್ನು 100 km ವರೆಗೆ ಬದಲಿಸಿ ದಿನಾಂಕ, ಲಭ್ಯತೆ, ವಿಶ್ವಾಸ ಮತ್ತು ವೇಗದ ಪ್ರತಿಕ್ರಿಯೆ ಫಿಲ್ಟರ್ ಬಳಸಿ.</string>
    <string name="tour_client_1_title">ಕ್ರಿಯೇಟರ್‌ಗಳನ್ನು ಹುಡುಕಿ (%1$d/%2$d)</string>
    <string name="tour_client_1_body">ಹತ್ತಿರದ ಫೋಟೋಗ್ರಾಫರ್ ಮತ್ತು ಕ್ರಿಯೇಟರ್‌ಗಳನ್ನು ಎಕ್ಸ್‌ಪ್ಲೋರ್‌ನಲ್ಲಿ ನೋಡಿ.</string>
    <string name="tour_client_2_title">ದಿನಾಂಕದಿಂದ ಫಿಲ್ಟರ್ ಮಾಡಿ (%1$d/%2$d)</string>
    <string name="tour_client_2_body">ದಿನಾಂಕ ಆಯ್ಕೆ ಮಾಡಿ ಆ ದಿನ ಲಭ್ಯವಿರುವ ಕ್ರಿಯೇಟರ್‌ಗಳನ್ನು ನೋಡಿ.</string>
    <string name="tour_client_3_title">ಕ್ರಿಯೇಟರ್‌ಗಳನ್ನು ಹೋಲಿಸಿ (%1$d/%2$d)</string>
    <string name="tour_client_3_body">ಎರಡರಿಂದ ನಾಲ್ಕು ಕ್ರಿಯೇಟರ್‌ಗಳ ರೇಟಿಂಗ್, ಸೇವೆ, ದೂರ ಮತ್ತು ಲಭ್ಯತೆಯನ್ನು ಹೋಲಿಸಿ.</string>
    <string name="tour_client_4_title">ನಿಮ್ಮ ಬುಕಿಂಗ್‌ಗಳು (%1$d/%2$d)</string>
    <string name="tour_client_4_body">ಬುಕಿಂಗ್, ಪಾವತಿ ಮತ್ತು ಕಾರ್ಯಕ್ರಮದ ಸ್ಥಿತಿಯನ್ನು ಇಲ್ಲಿ ನೋಡಿ.</string>
    <string name="tour_client_5_title">ಅಪ್‌ಡೇಟ್ ಪಡೆಯಿರಿ (%1$d/%2$d)</string>
    <string name="tour_client_5_body">ಬುಕಿಂಗ್, ಅನುಮೋದನೆ ಮತ್ತು ಮುಖ್ಯ ಸಂದೇಶಗಳನ್ನು ಅಧಿಸೂಚನೆಗಳಲ್ಲಿ ನೋಡಿ.</string>
    <string name="tour_client_6_title">ನಿಮ್ಮ ಪ್ರೊಫೈಲ್ (%1$d/%2$d)</string>
    <string name="tour_client_6_body">ಖಾತೆ, ಭಾಷೆ, ಗೌಪ್ಯತೆ ಮತ್ತು ಸಹಾಯವನ್ನು ಇಲ್ಲಿ ನಿರ್ವಹಿಸಿ.</string>
    <string name="tour_creator_1_title">ನಿಮ್ಮ ಡ್ಯಾಶ್‌ಬೋರ್ಡ್ (%1$d/%2$d)</string>
    <string name="tour_creator_1_body">ಕ್ಯಾಲೆಂಡರ್‌ನಲ್ಲಿ ಲಭ್ಯ ಮತ್ತು ಬ್ಯುಸಿ ದಿನಾಂಕಗಳನ್ನು ನಿರ್ವಹಿಸಿ.</string>
    <string name="tour_creator_2_title">ಲಭ್ಯತೆ ಹೊಂದಿಸಿ (%1$d/%2$d)</string>
    <string name="tour_creator_2_body">ದಿನಾಂಕ ಆಯ್ಕೆ ಮಾಡಿ Available ಅಥವಾ Busy ಎಂದು ಗುರುತಿಸಿ.</string>
    <string name="tour_creator_3_title">ಬುಕಿಂಗ್ ನಿರ್ವಹಿಸಿ (%1$d/%2$d)</string>
    <string name="tour_creator_3_body">ಕ್ಲೈಂಟ್ ವಿನಂತಿ, ಪಾವತಿ ಮತ್ತು ಕಾರ್ಯಕ್ರಮದ ಸ್ಥಿತಿಯನ್ನು ಇಲ್ಲಿ ನೋಡಿ.</string>
    <string name="tour_creator_4_title">ನಿಮ್ಮ ಪೋರ್ಟ್‌ಫೋಲಿಯೊ (%1$d/%2$d)</string>
    <string name="tour_creator_4_body">ಸಾರ್ವಜನಿಕ ಪ್ರೊಫೈಲ್, ಸೇವೆ, ಚಿತ್ರ ಮತ್ತು ಖಾತೆ ಆಯ್ಕೆಗಳನ್ನು ನಿರ್ವಹಿಸಿ.</string>
    <string name="tour_creator_5_title">ಚಿತ್ರಗಳನ್ನು ಅಪ್‌ಲೋಡ್ ಮಾಡಿ (%1$d/%2$d)</string>
    <string name="tour_creator_5_body">ನಿಮ್ಮ ಶೈಲಿ ಮತ್ತು ಗುಣಮಟ್ಟ ತೋರಿಸಲು ಅತ್ಯುತ್ತಮ ಕೆಲಸವನ್ನು ಪೋಸ್ಟ್ ಮಾಡಿ.</string>
    <string name="tour_creator_6_title">ಪರಿಶೀಲನೆ ಪೂರ್ಣಗೊಳಿಸಿ (%1$d/%2$d)</string>
    <string name="tour_creator_6_body">ಗುರುತು, ಪೋರ್ಟ್‌ಫೋಲಿಯೊ ಮತ್ತು ಸಾಮಾಜಿಕ ಪುರಾವೆ ಪೂರ್ಣಗೊಳಿಸಿ ವಿಶ್ವಾಸ ಹೆಚ್ಚಿಸಿ.</string>
    <string name="tour_guest_1_title">ಸ್ವಾಗತ (%1$d/%2$d)</string>
    <string name="tour_guest_1_body">ಸೈನ್ ಇನ್ ಮಾಡುವ ಮೊದಲೂ ಹತ್ತಿರದ ಕ್ರಿಯೇಟರ್‌ಗಳನ್ನು ನೋಡಬಹುದು.</string>
    <string name="tour_guest_2_title">ತ್ವರಿತವಾಗಿ ಹುಡುಕಿ (%1$d/%2$d)</string>
    <string name="tour_guest_2_body">ನಗರ, ಸೇವೆ ಅಥವಾ ಕ್ರಿಯೇಟರ್ ಹೆಸರನ್ನು ಟೈಪ್ ಮಾಡಿ ಹುಡುಕಿ.</string>
    <string name="tour_guest_3_title">ಸೈನ್ ಇನ್ ಮಾಡಿ (%1$d/%2$d)</string>
    <string name="tour_guest_3_body">ಫೇವರಿಟ್ ಉಳಿಸಲು, ಬುಕ್ ಮಾಡಲು ಮತ್ತು ಅಧಿಸೂಚನೆ ಪಡೆಯಲು ಸೈನ್ ಇನ್ ಮಾಡಿ.</string>
