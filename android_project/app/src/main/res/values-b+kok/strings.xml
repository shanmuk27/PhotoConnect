    <string name="tour_creator_2_title">उपलब्धताय सेट करात (%1$d/%2$d)</string>
    <string name="tour_creator_2_body">तारीख वेंचून Available वा Busy म्हणून खूण करात.</string>
    <string name="tour_creator_3_title">बुकिंगां सांबाळात (%1$d/%2$d)</string>
    <string name="tour_creator_3_body">क्लायंट विनंती, पेमेंट आनी इव्हेंट स्थिती पळयात.</string>
    <string name="tour_creator_4_title">तुमचो पोर्टफोलियो (%1$d/%2$d)</string>
    <string name="tour_creator_4_body">पब्लिक प्रोफायल, सेवा, फोटो आनी खाते पर्याय सांबाळात.</string>
    <string name="tour_creator_5_title">फोटो अपलोड करात (%1$d/%2$d)</string>
    <string name="tour_creator_5_body">तुमची शैली आनी दर्जो दाखोवपाक उत्तम काम पोस्ट करात.</string>
    <string name="tour_creator_6_title">तपासणी पुरी करात (%1$d/%2$d)</string>
    <string name="tour_creator_6_body">वळख, पोर्टफोलियो आनी सोशल पुरावे पुरे करून विस्वास वाडयात.</string>
    <string name="tour_guest_1_title">येवकार (%1$d/%2$d)</string>
    <string name="tour_guest_1_body">साइन इन करचे पयलींय लागींचे क्रिएटर पळोवं येतात.</string>
    <string name="tour_guest_2_title">बेगीन सोदात (%1$d/%2$d)</string>
    <string name="tour_guest_2_body">शार, सेवा वा क्रिएटराचें नांव बरयून सोदात.</string>
    <string name="tour_guest_3_title">साइन इन करात (%1$d/%2$d)</string>
    <string name="tour_guest_3_body">फेवरेट सेव, बुकिंग आनी सुचोवण्यां खातीर साइन इन करात.</string>
