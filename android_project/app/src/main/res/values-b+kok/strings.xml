    <string name="tour_client_3_title">क्रिएटरांची तुळा करात (%1$d/%2$d)</string>
    <string name="tour_client_3_body">दोन ते चार क्रिएटरांची रेटिंग, सेवा, अंतर आनी उपलब्धताय तुळा करात.</string>
    <string name="tour_client_4_title">तुमचीं बुकिंगां (%1$d/%2$d)</string>
    <string name="tour_client_4_body">बुकिंग, पेमेंट आनी इव्हेंट स्थिती हांगा पळयात.</string>
    <string name="tour_client_5_title">अपडेट मेळयात (%1$d/%2$d)</string>
    <string name="tour_client_5_body">बुकिंग, मान्यताय आनी म्हत्वाचे संदेश सुचोवण्यांनी पळयात.</string>
    <string name="tour_client_6_title">तुमचें प्रोफायल (%1$d/%2$d)</string>
    <string name="tour_client_6_body">खाते, भास, गुप्तताय आनी मदत हांगा सांबाळात.</string>
    <string name="tour_creator_1_title">तुमचो डॅशबोर्ड (%1$d/%2$d)</string>
