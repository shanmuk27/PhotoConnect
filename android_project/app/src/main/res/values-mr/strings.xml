    <string name="tour_explore_services_title">सेवा निवडा (%1$d/%2$d)</string>
    <string name="tour_explore_services_body">क्रिएटर यादी लगेच कमी करण्यासाठी लग्न, पोर्ट्रेट किंवा व्हिडिओसारखी सेवा निवडा.</string>
    <string name="tour_explore_results_title">क्रिएटर कार्ड (%1$d/%2$d)</string>
    <string name="tour_explore_results_body">फोटो, रेटिंग, सेवा, अंतर आणि विश्वासाचे संकेत पहा. तपशीलासाठी कार्ड आणि फेव्हरेटसाठी हृदय टॅप करा.</string>
    <string name="tour_explore_filters_title">जवळचे निकाल सुधारा (%1$d/%2$d)</string>
    <string name="tour_explore_filters_body">रेडियस 100 km पर्यंत बदला आणि तारीख, उपलब्धता, विश्वास व जलद प्रतिसाद फिल्टर वापरा.</string>
    <string name="tour_client_1_title">क्रिएटर शोधा (%1$d/%2$d)</string>
    <string name="tour_client_1_body">जवळचे फोटोग्राफर आणि क्रिएटर एक्सप्लोरमध्ये पहा.</string>
    <string name="tour_client_2_title">तारखेनुसार फिल्टर करा (%1$d/%2$d)</string>
    <string name="tour_client_2_body">तारीख निवडून त्या दिवशी उपलब्ध क्रिएटर पहा.</string>
    <string name="tour_client_3_title">क्रिएटरची तुलना करा (%1$d/%2$d)</string>
    <string name="tour_client_3_body">दोन ते चार क्रिएटरचे रेटिंग, सेवा, अंतर आणि उपलब्धता तुलना करा.</string>
    <string name="tour_client_4_title">तुमच्या बुकिंग (%1$d/%2$d)</string>
    <string name="tour_client_4_body">बुकिंग, पेमेंट आणि इव्हेंटची स्थिती येथे पहा.</string>
    <string name="tour_client_5_title">अपडेट मिळवा (%1$d/%2$d)</string>
    <string name="tour_client_5_body">बुकिंग, मंजुरी आणि महत्त्वाचे संदेश सूचनांमध्ये पहा.</string>
    <string name="tour_client_6_title">तुमचे प्रोफाइल (%1$d/%2$d)</string>
    <string name="tour_client_6_body">खाते, भाषा, गोपनीयता आणि मदत येथे व्यवस्थापित करा.</string>
    <string name="tour_creator_1_title">तुमचा डॅशबोर्ड (%1$d/%2$d)</string>
    <string name="tour_creator_1_body">कॅलेंडरमधून उपलब्ध आणि व्यस्त तारखा व्यवस्थापित करा.</string>
    <string name="tour_creator_2_title">उपलब्धता ठरवा (%1$d/%2$d)</string>
    <string name="tour_creator_2_body">तारीख निवडून Available किंवा Busy म्हणून चिन्हांकित करा.</string>
    <string name="tour_creator_3_title">बुकिंग व्यवस्थापित करा (%1$d/%2$d)</string>
    <string name="tour_creator_3_body">क्लायंटच्या विनंत्या, पेमेंट आणि इव्हेंटची स्थिती येथे पहा.</string>
    <string name="tour_creator_4_title">तुमचा पोर्टफोलिओ (%1$d/%2$d)</string>
    <string name="tour_creator_4_body">सार्वजनिक प्रोफाइल, सेवा, फोटो आणि खात्याचे पर्याय व्यवस्थापित करा.</string>
    <string name="tour_creator_5_title">फोटो अपलोड करा (%1$d/%2$d)</string>
    <string name="tour_creator_5_body">तुमची शैली आणि गुणवत्ता दाखवण्यासाठी सर्वोत्तम काम पोस्ट करा.</string>
    <string name="tour_creator_6_title">पडताळणी पूर्ण करा (%1$d/%2$d)</string>
    <string name="tour_creator_6_body">ओळख, पोर्टफोलिओ आणि सोशल पुरावे पूर्ण करून विश्वास वाढवा.</string>
    <string name="tour_guest_1_title">स्वागत आहे (%1$d/%2$d)</string>
    <string name="tour_guest_1_body">साइन इन करण्यापूर्वीही जवळचे क्रिएटर पाहू शकता.</string>
    <string name="tour_guest_2_title">जलद शोधा (%1$d/%2$d)</string>
    <string name="tour_guest_2_body">शहर, सेवा किंवा क्रिएटरचे नाव टाइप करून शोधा.</string>
    <string name="tour_guest_3_title">साइन इन करा (%1$d/%2$d)</string>
    <string name="tour_guest_3_body">फेव्हरेट सेव्ह करण्यासाठी, बुकिंग आणि सूचना मिळवण्यासाठी साइन इन करा.</string>
