    <string name="tour_explore_services_title">सर्विस सायख (%1$d/%2$d)</string>
    <string name="tour_explore_services_body">क्रिएटर लिस्टखौ खम खालामनो हाबा, पर्ट्रेट एबा भिडिअ सर्विस सायख।</string>
    <string name="tour_explore_results_title">क्रिएटर कार्ड (%1$d/%2$d)</string>
    <string name="tour_explore_results_body">फट, रेटिं, सर्विस, जानथाय आरो फोथायथिनि दाग नाय। गुवारै नायनो कार्ड आरो फेभरेटनि थाखाय हार्ट टेप खालाम।</string>
    <string name="tour_explore_filters_title">खाथिनि रिजाल्ट मोजां खालाम (%1$d/%2$d)</string>
    <string name="tour_explore_filters_body">रेडियासखौ 100 km सिम सोलाय आरो अक्टो, मोजां थानाय, फोथायथि आरो गोख्रै फिननाय फिल्टार बाहाय।</string>
    <string name="tour_client_1_title">क्रिएटर नागिर (%1$d/%2$d)</string>
    <string name="tour_client_1_body">खाथियाव थानाय फटग्राफार आरो क्रिएटरखौ एक्सप्लोराव नाय।</string>
    <string name="tour_client_2_title">अक्टो जों फिल्टार खालाम (%1$d/%2$d)</string>
    <string name="tour_client_2_body">अक्टो सायखना बे सानाव मोजां थानाय क्रिएटरखौ नाय।</string>
    <string name="tour_client_3_title">क्रिएटर रुजु (%1$d/%2$d)</string>
    <string name="tour_client_3_body">नै निफ्राय ब्रै क्रिएटरनि रेटिं, सर्विस, जानथाय आरो मोजां थानायखौ रुजु।</string>
    <string name="tour_client_4_title">नोंथांनि बुकिं (%1$d/%2$d)</string>
    <string name="tour_client_4_body">बुकिं, पेमेंट आरो इभेन्टनि थासारिखौ बेयाव नाय।</string>
    <string name="tour_client_5_title">आपडेट मोन (%1$d/%2$d)</string>
    <string name="tour_client_5_body">बुकिं, गनायथि आरो गोनां खौरांखौ मिथिसाराव नाय।</string>
    <string name="tour_client_6_title">नोंथांनि प्रफाइल (%1$d/%2$d)</string>
    <string name="tour_client_6_body">एकाउन्ट, राव, प्राइभेसी आरो हेल्पखौ बेयाव सामलाय।</string>
    <string name="tour_creator_1_title">नोंथांनि डेशबर्ड (%1$d/%2$d)</string>
    <string name="tour_creator_1_body">केलेन्डाराव मोजां आरो बिजि अक्टोखौ सामलाय।</string>
    <string name="tour_creator_2_title">मोजां थानायखौ सेट खालाम (%1$d/%2$d)</string>
    <string name="tour_creator_2_body">अक्टो सायखना Available एबा Busy महरै दाग हो।</string>
    <string name="tour_creator_3_title">बुकिं सामलाय (%1$d/%2$d)</string>
    <string name="tour_creator_3_body">क्लाइएन्टनि खावलायनाय, पेमेंट आरो इभेन्ट थासारिखौ नाय।</string>
    <string name="tour_creator_4_title">नोंथांनि पर्टफोलिअ (%1$d/%2$d)</string>
    <string name="tour_creator_4_body">पाब्लिक प्रफाइल, सर्विस, फट आरो एकाउन्ट अपसनखौ सामलाय।</string>
    <string name="tour_creator_5_title">फट आपलड खालाम (%1$d/%2$d)</string>
    <string name="tour_creator_5_body">नोंथांनि स्टाइल आरो गुनखौ दिन्थिनो साबसिन हाबाखौ पस्ट खालाम।</string>
    <string name="tour_creator_6_title">भेरिफिकेसन आबुं खालाम (%1$d/%2$d)</string>
    <string name="tour_creator_6_body">सिनायथि, पर्टफोलिअ आरो ससियेल प्रमानखौ आबुं खालाम।</string>
    <string name="tour_guest_1_title">बरायबाय (%1$d/%2$d)</string>
    <string name="tour_guest_1_body">साइन इननि सिगांबो खाथिनि क्रिएटरखौ नायनो हायो।</string>
    <string name="tour_guest_2_title">गोख्रै नागिर (%1$d/%2$d)</string>
    <string name="tour_guest_2_body">सहर, सर्विस एबा क्रिएटरनि मुं लिरना नागिर।</string>
    <string name="tour_guest_3_title">साइन इन खालाम (%1$d/%2$d)</string>
    <string name="tour_guest_3_body">फेभरेट सेभ, बुकिं आरो मिथिसारनि थाखाय साइन इन खालाम।</string>
