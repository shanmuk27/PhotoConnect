    <string name="tour_client_4_title">My Bookings (%1$d/%2$d)</string>
    <string name="tour_client_4_body">Events tab ۾ bookings، payments، pending dues، calls، sharing ۽ booking status هڪ جاءِ تي ملن ٿا.</string>
    <string name="tour_client_5_title">Notifications (%1$d/%2$d)</string>
