    <string name="tour_creator_3_title">Client bookings (%1$d/%2$d)</string>
    <string name="tour_creator_3_body">Events Notebook ۾ client events، payments، pending dues، calls، sharing، cancellation status ۽ analytics هوندا آهن.</string>
