    <string name="tour_client_3_title">क्रिएटर तुलना गर्नुहोस् (%1$d/%2$d)</string>
    <string name="tour_client_3_body">दुईदेखि चार क्रिएटरको रेटिङ, सेवा, दूरी र उपलब्धता तुलना गर्नुहोस्।</string>
    <string name="tour_client_4_title">तपाईंका बुकिङ (%1$d/%2$d)</string>
    <string name="tour_client_4_body">बुकिङ, भुक्तानी र इभेन्टको अवस्था यहाँ हेर्नुहोस्।</string>
    <string name="tour_client_5_title">अपडेट पाउनुहोस् (%1$d/%2$d)</string>
    <string name="tour_client_5_body">बुकिङ, स्वीकृति र महत्त्वपूर्ण सन्देश सूचनामा हेर्नुहोस्।</string>
    <string name="tour_client_6_title">तपाईंको प्रोफाइल (%1$d/%2$d)</string>
    <string name="tour_client_6_body">खाता, भाषा, गोपनीयता र सहायता यहाँ व्यवस्थापन गर्नुहोस्।</string>
