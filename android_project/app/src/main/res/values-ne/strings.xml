    <string name="tour_creator_2_body">मिति छानेर Available वा Busy चिन्ह लगाउनुहोस्।</string>
    <string name="tour_creator_3_title">बुकिङ व्यवस्थापन गर्नुहोस् (%1$d/%2$d)</string>
    <string name="tour_creator_3_body">क्लाइन्ट अनुरोध, भुक्तानी र इभेन्टको अवस्था यहाँ हेर्नुहोस्।</string>
    <string name="tour_creator_4_title">तपाईंको पोर्टफोलियो (%1$d/%2$d)</string>
    <string name="tour_creator_4_body">सार्वजनिक प्रोफाइल, सेवा, फोटो र खाता विकल्प व्यवस्थापन गर्नुहोस्।</string>
    <string name="tour_creator_5_title">फोटो अपलोड गर्नुहोस् (%1$d/%2$d)</string>
    <string name="tour_creator_5_body">आफ्नो शैली र गुणस्तर देखाउन उत्कृष्ट काम पोस्ट गर्नुहोस्।</string>
    <string name="tour_creator_6_title">प्रमाणीकरण पूरा गर्नुहोस् (%1$d/%2$d)</string>
    <string name="tour_creator_6_body">पहिचान, पोर्टफोलियो र सामाजिक प्रमाण पूरा गरी विश्वास बढाउनुहोस्।</string>
    <string name="tour_guest_1_title">स्वागत छ (%1$d/%2$d)</string>
    <string name="tour_guest_1_body">साइन इन गर्नुअघि पनि नजिकका क्रिएटर हेर्न सक्नुहुन्छ।</string>
    <string name="tour_guest_2_title">छिटो खोज्नुहोस् (%1$d/%2$d)</string>
    <string name="tour_guest_2_body">सहर, सेवा वा क्रिएटरको नाम टाइप गरेर खोज्नुहोस्।</string>
    <string name="tour_guest_3_title">साइन इन गर्नुहोस् (%1$d/%2$d)</string>
    <string name="tour_guest_3_body">मनपर्ने सेव गर्न, बुकिङ गर्न र सूचना पाउन साइन इन गर्नुहोस्।</string>
