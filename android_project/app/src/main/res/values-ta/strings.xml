    <string name="tour_explore_services_title">சேவைகளைத் தேர்ந்தெடுக்கவும் (%1$d/%2$d)</string>
    <string name="tour_explore_services_body">பட்டியலை உடனே குறைக்க திருமணம், போர்ட்ரெட் அல்லது வீடியோ போன்ற சேவையைத் தேர்ந்தெடுக்கவும்.</string>
    <string name="tour_explore_results_title">கிரியேட்டர் கார்டுகள் (%1$d/%2$d)</string>
    <string name="tour_explore_results_body">படங்கள், மதிப்பீடு, சேவைகள், தூரம் மற்றும் நம்பிக்கை அறிகுறிகளைப் பாருங்கள். விவரங்களுக்கு கார்டையும் பிடித்ததற்கு இதயத்தையும் தட்டவும்.</string>
    <string name="tour_explore_filters_title">அருகிலுள்ள முடிவுகளை மேம்படுத்தவும் (%1$d/%2$d)</string>
    <string name="tour_explore_filters_body">ஆரத்தை 100 km வரை மாற்றி தேதி, கிடைப்பு, நம்பிக்கை மற்றும் விரைவு பதில் வடிகட்டிகளைப் பயன்படுத்தவும்.</string>
    <string name="tour_client_1_title">கிரியேட்டர்களைக் கண்டறியுங்கள் (%1$d/%2$d)</string>
    <string name="tour_client_1_body">அருகிலுள்ள புகைப்படக் கலைஞர்கள் மற்றும் கிரியேட்டர்களை எக்ஸ்ப்ளோரில் பாருங்கள்.</string>
    <string name="tour_client_2_title">தேதியால் வடிகட்டுங்கள் (%1$d/%2$d)</string>
    <string name="tour_client_2_body">தேதியைத் தேர்ந்து அன்று கிடைக்கும் கிரியேட்டர்களை மட்டும் பாருங்கள்.</string>
    <string name="tour_client_3_title">கிரியேட்டர்களை ஒப்பிடுங்கள் (%1$d/%2$d)</string>
    <string name="tour_client_3_body">இரண்டு முதல் நான்கு கிரியேட்டர்களின் மதிப்பீடு, சேவை, தூரம் மற்றும் கிடைப்பை ஒப்பிடுங்கள்.</string>
    <string name="tour_client_4_title">உங்கள் முன்பதிவுகள் (%1$d/%2$d)</string>
    <string name="tour_client_4_body">முன்பதிவுகள், கட்டணங்கள் மற்றும் நிகழ்வு நிலையை இங்கே பாருங்கள்.</string>
    <string name="tour_client_5_title">புதுப்பிப்புகளைப் பெறுங்கள் (%1$d/%2$d)</string>
    <string name="tour_client_5_body">முன்பதிவு, ஒப்புதல் மற்றும் முக்கிய செய்திகளை அறிவிப்புகளில் பாருங்கள்.</string>
    <string name="tour_client_6_title">உங்கள் சுயவிவரம் (%1$d/%2$d)</string>
    <string name="tour_client_6_body">கணக்கு, மொழி, தனியுரிமை மற்றும் உதவியை இங்கே நிர்வகிக்கவும்.</string>
    <string name="tour_creator_1_title">உங்கள் டாஷ்போர்டு (%1$d/%2$d)</string>
    <string name="tour_creator_1_body">காலண்டரில் கிடைக்கும் மற்றும் பிஸியான தேதிகளை நிர்வகிக்கவும்.</string>
    <string name="tour_creator_2_title">கிடைப்பை அமைக்கவும் (%1$d/%2$d)</string>
    <string name="tour_creator_2_body">தேதியைத் தேர்ந்து Available அல்லது Busy என குறிக்கவும்.</string>
    <string name="tour_creator_3_title">முன்பதிவுகளை நிர்வகிக்கவும் (%1$d/%2$d)</string>
    <string name="tour_creator_3_body">வாடிக்கையாளர் கோரிக்கைகள், கட்டணங்கள் மற்றும் நிகழ்வு நிலையை இங்கே பாருங்கள்.</string>
    <string name="tour_creator_4_title">உங்கள் போர்ட்ஃபோலியோ (%1$d/%2$d)</string>
    <string name="tour_creator_4_body">பொது சுயவிவரம், சேவைகள், படங்கள் மற்றும் கணக்கு விருப்பங்களை நிர்வகிக்கவும்.</string>
    <string name="tour_creator_5_title">படங்களைப் பதிவேற்றுங்கள் (%1$d/%2$d)</string>
    <string name="tour_creator_5_body">உங்கள் பாணி மற்றும் தரத்தை காட்ட சிறந்த படைப்புகளைப் பதிவிடுங்கள்.</string>
    <string name="tour_creator_6_title">சரிபார்ப்பை முடிக்கவும் (%1$d/%2$d)</string>
    <string name="tour_creator_6_body">அடையாளம், போர்ட்ஃபோலியோ மற்றும் சமூக ஆதாரத்தை பூர்த்தி செய்து நம்பிக்கையை வளர்க்கவும்.</string>
    <string name="tour_guest_1_title">வரவேற்கிறோம் (%1$d/%2$d)</string>
    <string name="tour_guest_1_body">சைன் இன் செய்யும் முன்பும் அருகிலுள்ள கிரியேட்டர்களைப் பார்க்கலாம்.</string>
    <string name="tour_guest_2_title">விரைவாகத் தேடுங்கள் (%1$d/%2$d)</string>
    <string name="tour_guest_2_body">நகரம், சேவை அல்லது கிரியேட்டர் பெயரைத் தட்டச்சு செய்து தேடுங்கள்.</string>
    <string name="tour_guest_3_title">சைன் இன் செய்யுங்கள் (%1$d/%2$d)</string>
    <string name="tour_guest_3_body">பிடித்தவற்றை சேமிக்க, முன்பதிவு செய்ய மற்றும் அறிவிப்புகளைப் பெற சைன் இன் செய்யுங்கள்.</string>
</resources>
