    <string name="tour_explore_services_title">സേവനങ്ങൾ തിരഞ്ഞെടുക്കുക (%1$d/%2$d)</string>
    <string name="tour_explore_services_body">പട്ടിക വേഗത്തിൽ ചുരുക്കാൻ വിവാഹം, പോർട്രെയിറ്റ് അല്ലെങ്കിൽ വീഡിയോ പോലുള്ള സേവനം തിരഞ്ഞെടുക്കുക.</string>
    <string name="tour_explore_results_title">ക്രിയേറ്റർ കാർഡുകൾ (%1$d/%2$d)</string>
    <string name="tour_explore_results_body">ചിത്രം, റേറ്റിംഗ്, സേവനം, ദൂരം, വിശ്വാസ സൂചനകൾ എന്നിവ കാണുക. വിവരത്തിന് കാർഡും ഫേവറിറ്റിന് ഹൃദയവും ടാപ്പ് ചെയ്യുക.</string>
    <string name="tour_explore_filters_title">സമീപ ഫലങ്ങൾ മെച്ചപ്പെടുത്തുക (%1$d/%2$d)</string>
    <string name="tour_explore_filters_body">റേഡിയസ് 100 km വരെ മാറ്റി തീയതി, ലഭ്യത, വിശ്വാസം, വേഗത്തിലുള്ള മറുപടി ഫിൽട്ടറുകൾ ഉപയോഗിക്കുക.</string>
    <string name="tour_client_1_title">ക്രിയേറ്റർമാരെ കണ്ടെത്തുക (%1$d/%2$d)</string>
    <string name="tour_client_1_body">സമീപത്തെ ഫോട്ടോഗ്രാഫർമാരെയും ക്രിയേറ്റർമാരെയും എക്സ്പ്ലോറിൽ കാണുക.</string>
    <string name="tour_client_2_title">തീയതി ഉപയോഗിച്ച് ഫിൽട്ടർ ചെയ്യുക (%1$d/%2$d)</string>
    <string name="tour_client_2_body">തീയതി തിരഞ്ഞെടുത്ത് ആ ദിവസം ലഭ്യമായ ക്രിയേറ്റർമാരെ കാണുക.</string>
    <string name="tour_client_3_title">ക്രിയേറ്റർമാരെ താരതമ്യം ചെയ്യുക (%1$d/%2$d)</string>
    <string name="tour_client_3_body">രണ്ട് മുതൽ നാല് ക്രിയേറ്റർമാരുടെ റേറ്റിംഗ്, സേവനം, ദൂരം, ലഭ്യത എന്നിവ താരതമ്യം ചെയ്യുക.</string>
    <string name="tour_client_4_title">നിങ്ങളുടെ ബുക്കിംഗുകൾ (%1$d/%2$d)</string>
    <string name="tour_client_4_body">ബുക്കിംഗ്, പേയ്‌മെന്റ്, ഇവന്റ് നില എന്നിവ ഇവിടെ കാണുക.</string>
    <string name="tour_client_5_title">അപ്‌ഡേറ്റുകൾ നേടുക (%1$d/%2$d)</string>
    <string name="tour_client_5_body">ബുക്കിംഗ്, അംഗീകാരം, പ്രധാന സന്ദേശങ്ങൾ എന്നിവ നോട്ടിഫിക്കേഷനിൽ കാണുക.</string>
    <string name="tour_client_6_title">നിങ്ങളുടെ പ്രൊഫൈൽ (%1$d/%2$d)</string>
    <string name="tour_client_6_body">അക്കൗണ്ട്, ഭാഷ, സ്വകാര്യത, സഹായം എന്നിവ ഇവിടെ നിയന്ത്രിക്കുക.</string>
    <string name="tour_creator_1_title">നിങ്ങളുടെ ഡാഷ്‌ബോർഡ് (%1$d/%2$d)</string>
    <string name="tour_creator_1_body">കലണ്ടറിൽ ലഭ്യവും തിരക്കുള്ളതുമായ തീയതികൾ നിയന്ത്രിക്കുക.</string>
    <string name="tour_creator_2_title">ലഭ്യത സജ്ജമാക്കുക (%1$d/%2$d)</string>
    <string name="tour_creator_2_body">തീയതി തിരഞ്ഞെടുത്ത് Available അല്ലെങ്കിൽ Busy ആയി അടയാളപ്പെടുത്തുക.</string>
    <string name="tour_creator_3_title">ബുക്കിംഗ് നിയന്ത്രിക്കുക (%1$d/%2$d)</string>
    <string name="tour_creator_3_body">ക്ലയന്റ് അഭ്യർത്ഥന, പേയ്‌മെന്റ്, ഇവന്റ് നില എന്നിവ ഇവിടെ കാണുക.</string>
    <string name="tour_creator_4_title">നിങ്ങളുടെ പോർട്ട്‌ഫോളിയോ (%1$d/%2$d)</string>
    <string name="tour_creator_4_body">പബ്ലിക് പ്രൊഫൈൽ, സേവനം, ചിത്രം, അക്കൗണ്ട് ഓപ്ഷനുകൾ എന്നിവ നിയന്ത്രിക്കുക.</string>
    <string name="tour_creator_5_title">ചിത്രങ്ങൾ അപ്‌ലോഡ് ചെയ്യുക (%1$d/%2$d)</string>
    <string name="tour_creator_5_body">നിങ്ങളുടെ ശൈലിയും നിലവാരവും കാണിക്കാൻ മികച്ച പ്രവർത്തികൾ പോസ്റ്റ് ചെയ്യുക.</string>
    <string name="tour_creator_6_title">വെരിഫിക്കേഷൻ പൂർത്തിയാക്കുക (%1$d/%2$d)</string>
    <string name="tour_creator_6_body">ഐഡന്റിറ്റി, പോർട്ട്‌ഫോളിയോ, സോഷ്യൽ തെളിവ് എന്നിവ പൂർത്തിയാക്കി വിശ്വാസം വർധിപ്പിക്കുക.</string>
    <string name="tour_guest_1_title">സ്വാഗതം (%1$d/%2$d)</string>
    <string name="tour_guest_1_body">സൈൻ ഇൻ ചെയ്യുന്നതിന് മുമ്പും സമീപത്തെ ക്രിയേറ്റർമാരെ കാണാം.</string>
    <string name="tour_guest_2_title">വേഗത്തിൽ തിരയുക (%1$d/%2$d)</string>
    <string name="tour_guest_2_body">നഗരം, സേവനം അല്ലെങ്കിൽ ക്രിയേറ്ററുടെ പേര് ടൈപ്പ് ചെയ്ത് തിരയുക.</string>
    <string name="tour_guest_3_title">സൈൻ ഇൻ ചെയ്യുക (%1$d/%2$d)</string>
    <string name="tour_guest_3_body">ഫേവറിറ്റുകൾ സേവ് ചെയ്യാനും ബുക്ക് ചെയ്യാനും നോട്ടിഫിക്കേഷൻ ലഭിക്കാനും സൈൻ ഇൻ ചെയ്യുക.</string>
</resources>
